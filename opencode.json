{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "agent": {
    "plan": {
      "prompt": "{file:./prompts/plan.md}",
      "color": "primary"
    },
    "build": {
      "prompt": "{file:./prompts/build.md}",
      "color": "secondary"
    },
    "audit": {
      "prompt": "{file:./prompts/audit.md}",
      "color": "accent"
    }
  },
  "permission": {
    "bash": {
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "wc *": "allow",
      "ls*": "allow",
      "tree *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ag *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "tr *": "allow",
      "awk *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "diff *": "allow",
      "comm *": "allow",
      "column *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "which *": "allow",
      "printenv*": "allow",
      "env": "allow",
      "echo *": "allow",
      "pwd": "allow",
      "whoami": "allow",
      "id": "allow",
      "uname *": "allow",
      "date *": "allow",
      "hostname": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git tag*": "allow",
      "git remote*": "allow",
      "git rev-parse*": "allow",
      "git rev-list*": "allow",
      "git shortlog*": "allow",
      "git describe*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git cat-file*": "allow",
      "git reflog*": "allow",
      "git config --get*": "allow",
      "git stash list*": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh pr diff*": "allow",
      "gh pr status*": "allow",
      "gh pr checks*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh issue status*": "allow",
      "gh repo view*": "allow",
      "gh repo list*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh auth status*": "allow",
      "gh api *": "allow",
      "gh project list*": "allow",
      "curl*": "allow",
      "ntfy publish*": "allow",
      "source ~/.config/opencode/skills/vault-triage/notify.sh*": "allow",
      "notify_triage *": "allow",
      "bash ~/.config/opencode/skills/vault-triage/triage-dashboard.sh*": "allow"
    }
  }
}
