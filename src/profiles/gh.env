# GitHub user profile — SSH-prefer, standard Linux/WSL workstation
# Usage: bun run install-config -- --profile gh/<github-username>
#
# NOTE: These paths are intentionally identical to host.env. The gh/* profile
# family differs only in the AoE sandbox config (gh.aoe.toml), not the host
# directory layout. Keeping a separate .env allows future per-family overrides
# without touching the host profile.
CONFIG_DIR="$HOME/.config/opencode"
OPENCODE_CONFIG_SRC="$HOME/.config/opencode"
SANDBOX_CONFIG_DIR="$HOME/.config/opencode-sandbox"
